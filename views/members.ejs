<%- include('templates/header') %>

<h1 class="mb-4">Hello, <%= name %>.</h1>

<h2 class="mb-3">Cats!</h2>
<div class="row g-3">
    <% images.forEach(function(img) { %>
    <div class="col-12 col-md-4">
        <img src="/<%= img %>"
             alt="Cat"
             class="img-fluid rounded <%= img === randomImage ? 'border border-3 border-primary shadow' : '' %>"
        />
    </div>
    <% }); %>
</div>

<div class="mt-4">
    <a href="/logout" class="btn btn-outline-secondary">Sign Out</a>
</div>

<%- include('templates/footer') %>